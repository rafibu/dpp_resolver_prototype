# query-client local configuration (copy to .env and adjust).
# All values are optional; defaults shown.

# Base URL of the DPP resolver (used for GET /admin/platforms).
RESOLVER_BASE_URL=http://localhost:8080

# Path appended to each platform base URL for the platform-local predicate query.
PLATFORM_QUERY_PATH=/query/predicate

# HTTP method used for the platform-local query (the prototype spec uses POST).
PLATFORM_QUERY_METHOD=POST

# Federation timeout applied when a request omits timeout_ms (milliseconds).
DEFAULT_TIMEOUT_MS=120000

# Per-platform HTTP connect/read timeouts (milliseconds).
HTTP_CONNECT_TIMEOUT_MS=5000
HTTP_READ_TIMEOUT_MS=120000

# Comma-separated CORS origins for the Angular frontend ("*" allows all).
CORS_ALLOW_ORIGINS=*
